# Copy to .env for local development. In production, prefer *_FILE mounted secrets.
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Infrastructure DSNs (match docker-compose service names when running in compose)
DATABASE_URL=postgresql+asyncpg://agentverse:agentverse@localhost:5432/agentverse
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO for local dev, S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# SSO / Keycloak (postgres-backed for persistent state)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=agentverse
KEYCLOAK_CLIENT_ID=agentverse-backend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_DB_PASSWORD=keycloak
SSO_ENABLED=false

# Observability (leave OTEL endpoint empty to disable exporting locally)
SERVICE_NAME=agentverse-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── LLM providers (set at least one for real goal execution) ────────────────
DEFAULT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...     # Voyage AI for best RAG embeddings
# GOOGLE_API_KEY=...        # Gemini embeddings
# SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2  # local CPU embeddings (no API key)

# ── A2A (Agent-to-Agent) protocol ───────────────────────────────────────────
# A2A_TENANT_ID=            # REQUIRED for the /a2a/tasks endpoint to work
# A2A_SHARED_SECRET=        # HMAC-SHA256 signing secret; empty = auth disabled (dev only)

# ── Slack integration ────────────────────────────────────────────────────────
# SLACK_TENANT_ID=          # tenant_id for goals triggered via Slack
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APPROVAL_CHANNEL=hitl-approvals

# ── Zapier integration ───────────────────────────────────────────────────────
# ZAPIER_TENANT_ID=         # tenant_id for goals triggered via Zapier
# ZAPIER_WEBHOOK_SECRET=

# ── IMAP email-to-goal listener ─────────────────────────────────────────────
IMAP_ENABLED=false
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=goals@example.com
# IMAP_PASSWORD=
# IMAP_SSL=true
# IMAP_MAILBOX=INBOX
# IMAP_TENANT_ID=

# ── SMTP outbound email (MailPit for local dev) ──────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_TLS=false

# ── Runtime tuning ───────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=90
AGENTVERSE_DB_SCHEDULE_DISCOVERY=true
EMBEDDING_DIM=1536

# ── MCP Built-in Servers ─────────────────────────────────────────────────────
# GITHUB_TOKEN=
# POSTGRES_MCP_URL=
POSTGRES_MCP_ALLOW_WRITES=false

# ── Shell execution (disabled by default for security) ───────────────────────
AGENTVERSE_ALLOW_SHELL_EXEC=false
AGENTVERSE_ALLOW_SUBPROCESS_EXEC=false

# ── SearXNG ──────────────────────────────────────────────────────────────────
SEARXNG_URL=http://searxng:8080

# ── Production model routing ─────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=anthropic
