# Copy to .env for local development. In production, prefer *_FILE mounted secrets.
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:5173

# Infrastructure DSNs (match docker-compose service names when running in compose)
DATABASE_URL=postgresql+asyncpg://agentverse:agentverse@localhost:5432/agentverse
REDIS_URL=redis://localhost:6379/0

# Observability (leave OTEL endpoint empty to disable exporting locally)
SERVICE_NAME=agentverse-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

# LLM default provider (vendor-agnostic; key resolved via vault/secret in later phases)
DEFAULT_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
