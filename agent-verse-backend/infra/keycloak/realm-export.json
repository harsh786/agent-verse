{
  "realm": "agentverse",
  "displayName": "AgentVerse",
  "enabled": true,
  "registrationAllowed": false,
  "loginTheme": "keycloak",
  "clients": [
    {
      "clientId": "agentverse-backend",
      "name": "AgentVerse Backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "agentverse-dev-secret",
      "redirectUris": ["http://localhost:8000/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:8000", "http://localhost:5173"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "agentverse-frontend",
      "name": "AgentVerse Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:5173/*", "http://localhost:8000/*"],
      "webOrigins": ["http://localhost:5173", "http://localhost:8000"],
      "protocol": "openid-connect",
      "standardFlowEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {"name": "admin", "description": "Full platform access"},
      {"name": "operator", "description": "Can submit goals, manage agents"},
      {"name": "viewer", "description": "Read-only access"},
      {"name": "approver", "description": "Can approve HITL requests"}
    ]
  },
  "users": [
    {
      "username": "admin@agentverse.local",
      "email": "admin@agentverse.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "admin123", "temporary": false}],
      "realmRoles": ["admin"]
    },
    {
      "username": "operator@agentverse.local",
      "email": "operator@agentverse.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{"type": "password", "value": "operator123", "temporary": false}],
      "realmRoles": ["operator"]
    }
  ],
  "defaultRoles": ["operator"]
}
