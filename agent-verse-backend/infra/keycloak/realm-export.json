{
  "realm": "agentverse",
  "enabled": true,
  "displayName": "AgentVerse",
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "agentverse-backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "agentverse-backend-secret",
      "redirectUris": ["http://localhost:8000/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:8000", "http://localhost:5173"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "agentverse-frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false
    }
  ],
  "roles": {
    "realm": [
      {"name": "admin", "description": "Platform administrator"},
      {"name": "operator", "description": "Can submit and manage goals"},
      {"name": "approver", "description": "Can approve HITL requests"},
      {"name": "viewer", "description": "Read-only access"}
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@agentverse.local",
      "credentials": [{"type": "password", "value": "admin123", "temporary": false}],
      "realmRoles": ["admin", "operator", "approver", "viewer"]
    }
  ],
  "identityProviders": [],
  "components": {},
  "internationalizationEnabled": false,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": false
}
