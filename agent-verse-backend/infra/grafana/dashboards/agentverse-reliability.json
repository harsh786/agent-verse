{
  "title": "AgentVerse Reliability",
  "uid": "agentverse-reliability",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Circuit Breaker States",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (server_id) (agentverse_circuit_breaker_state)", "legendFormat": "{{server_id}}"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "CLOSED", "color": "green"}, "1": {"text": "OPEN", "color": "red"}, "2": {"text": "HALF-OPEN", "color": "yellow"}}}]}}
    },
    {
      "id": 2,
      "title": "Retry Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "rate(agentverse_goal_retries_total[5m])", "legendFormat": "Retries/s"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "orange"}}}
    },
    {
      "id": 3,
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "agentverse_queue_depth{queue=\"goals_dlq\"}", "legendFormat": "DLQ Depth"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}}
    },
    {
      "id": 4,
      "title": "Queue Depths Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "targets": [
        {"expr": "agentverse_queue_depth{queue=\"goals\"}", "legendFormat": "Goals"},
        {"expr": "agentverse_queue_depth{queue=\"schedules\"}", "legendFormat": "Schedules"},
        {"expr": "agentverse_queue_depth{queue=\"maintenance\"}", "legendFormat": "Maintenance"},
        {"expr": "agentverse_queue_depth{queue=\"goals_dlq\"}", "legendFormat": "DLQ"}
      ]
    },
    {
      "id": 5,
      "title": "Error Rate by Type",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {"expr": "rate(agentverse_goal_failed_total[5m])", "legendFormat": "Goal Failures"},
        {"expr": "rate(agentverse_mcp_tool_errors_total[5m])", "legendFormat": "MCP Tool Errors"},
        {"expr": "rate(agentverse_circuit_breaker_trips_total[5m])", "legendFormat": "Circuit Trips"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}}
    },
    {
      "id": 6,
      "title": "HITL Pending Approvals",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "agentverse_hitl_pending_approvals", "legendFormat": "Pending"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}}
    }
  ]
}
