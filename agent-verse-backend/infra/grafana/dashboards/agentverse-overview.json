{
  "title": "AgentVerse Overview",
  "uid": "agentverse-overview",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Goals Submitted (Last Hour)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "increase(agentverse_goal_submitted_total[1h])", "legendFormat": "Goals"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}}
    },
    {
      "id": 2,
      "title": "Active Goals",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "agentverse_active_goals", "legendFormat": "Active"}],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}}}
    },
    {
      "id": 3,
      "title": "Goal Success Rate",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "rate(agentverse_goal_completed_total[1h]) / (rate(agentverse_goal_completed_total[1h]) + rate(agentverse_goal_failed_total[1h])) * 100", "legendFormat": "Success %"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 100, "unit": "percent"}}
    },
    {
      "id": 4,
      "title": "Goal Duration P99 (seconds)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, rate(agentverse_goal_duration_seconds_bucket[5m]))", "legendFormat": "P99"}]
    },
    {
      "id": 5,
      "title": "Goals Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(agentverse_goal_submitted_total[5m])", "legendFormat": "Submitted"},
        {"expr": "rate(agentverse_goal_completed_total[5m])", "legendFormat": "Completed"},
        {"expr": "rate(agentverse_goal_failed_total[5m])", "legendFormat": "Failed"}
      ]
    }
  ]
}
