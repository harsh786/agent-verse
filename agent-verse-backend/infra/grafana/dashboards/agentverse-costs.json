{
  "title": "AgentVerse Costs",
  "uid": "agentverse-costs",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Cost Per Tenant (Last Hour)",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (tenant_id) (increase(agentverse_llm_cost_total[1h]))", "legendFormat": "{{tenant_id}}"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "color": {"mode": "palette-classic"}}}
    },
    {
      "id": 2,
      "title": "Token Usage Per Tenant (Last Hour)",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "sum by (tenant_id) (increase(agentverse_llm_tokens_total[1h]))", "legendFormat": "{{tenant_id}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}}
    },
    {
      "id": 3,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {"expr": "rate(agentverse_llm_cost_total[5m])", "legendFormat": "Cost/s"},
        {"expr": "rate(agentverse_llm_tokens_total[5m])", "legendFormat": "Tokens/s"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}}
    },
    {
      "id": 4,
      "title": "Budget Remaining (% of limit)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "1 - (agentverse_budget_used_total / agentverse_budget_limit_total)", "legendFormat": "Remaining"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit", "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.2}, {"color": "green", "value": 0.5}]}}}
    },
    {
      "id": 5,
      "title": "LLM Provider Breakdown",
      "type": "piechart",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "sum by (provider) (increase(agentverse_llm_cost_total[24h]))", "legendFormat": "{{provider}}"}],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}}
    }
  ]
}
