{
  "title": "AgentVerse Platform",
  "uid": "agentverse-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "tags": ["agentverse", "production"],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Goals",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "title": "Goal Completion Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "complete" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(agentverse_goal_total{status=\"complete\"}[5m])",
          "legendFormat": "complete",
          "refId": "A"
        },
        {
          "expr": "rate(agentverse_goal_total{status=\"failed\"}[5m])",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Goals Started (5m)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "min": 0,
          "max": 200
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(agentverse_goal_total{status=\"started\"}[5m])) or vector(0)",
          "legendFormat": "Goals Started",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Goal Execution Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(agentverse_goal_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(agentverse_goal_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(agentverse_goal_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "title": "Cost",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Daily Spend by Scope",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum by (scope) (increase(agentverse_cost_usd_total[24h]))",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Per-Goal Cost Trend",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(agentverse_cost_usd_total[1h])",
          "legendFormat": "cost/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Budget Utilization",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(agentverse_cost_usd_total[30d])) / 1000",
          "legendFormat": "Budget Used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "title": "Tool Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "title": "Tool Call Success Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (tool) (rate(agentverse_tool_call_total{status=\"success\"}[5m])) / sum by (tool) (rate(agentverse_tool_call_total[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Tool Call Latency by Tool (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (tool, le) (rate(agentverse_tool_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tool}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (tool, le) (rate(agentverse_tool_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tool}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (tool, le) (rate(agentverse_tool_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tool}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 23,
      "title": "Circuit Breaker Open Count",
      "type": "stat",
      "gridPos": { "x": 20, "y": 19, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "count(agentverse_tool_call_total{status=\"circuit_open\"}) or vector(0)",
          "legendFormat": "Open Circuits",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "title": "Queue Depth",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "title": "Celery Goals Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "agentverse_queue_depth{queue=\"goals\"}",
          "legendFormat": "goals",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "title": "Celery Schedules Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "agentverse_queue_depth{queue=\"schedules\"}",
          "legendFormat": "schedules",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Celery Maintenance Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "agentverse_queue_depth{queue=\"maintenance\"}",
          "legendFormat": "maintenance",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "title": "RAG Performance",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "title": "RAG Search Latency p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agentverse_tool_call_duration_seconds_bucket{tool=\"rag\"}[5m]))",
          "legendFormat": "p95 RAG search",
          "refId": "A"
        }
      ]
    },
    {
      "id": 42,
      "title": "RAG Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "rate(agentverse_tool_call_total{tool=\"rag\",status=\"cache_hit\"}[5m]) / rate(agentverse_tool_call_total{tool=\"rag\"}[5m])",
          "legendFormat": "Cache Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 43,
      "title": "Documents Indexed",
      "type": "stat",
      "gridPos": { "x": 16, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(agentverse_tool_call_total{tool=\"rag\",status=\"success\"}) or vector(0)",
          "legendFormat": "Documents Indexed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 44,
      "title": "Approval Wait p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 45, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agentverse_approval_wait_seconds_bucket[5m]))",
          "legendFormat": "p95 approval wait",
          "refId": "A"
        }
      ]
    },
    {
      "id": 45,
      "title": "Connector Auth and Tool Errors",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 45, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (connector, status) (rate(agentverse_tool_call_total{status=\"error\"}[5m]))",
          "legendFormat": "{{connector}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 46,
      "title": "Worker Queue Health",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 45, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (queue) (agentverse_queue_depth)",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 47,
      "title": "Schedule Fires",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 45, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (status) (increase(agentverse_schedule_fire_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "title": "Platform Usage",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 54, "w": 24, "h": 1 }
    },
    {
      "id": 51,
      "title": "Requests per Minute by Priority",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 55, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum by (priority) (rate(agentverse_goal_total[1m]))",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 52,
      "title": "Goals by Status",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 55, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum by (status) (increase(agentverse_goal_total[24h]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 53,
      "title": "Active Priority Buckets",
      "type": "stat",
      "gridPos": { "x": 16, "y": 55, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "count(count by (priority) (rate(agentverse_goal_total[5m]))) or vector(0)",
          "legendFormat": "Active Priority Buckets",
          "refId": "A"
        }
      ]
    }
  ]
}
